<!DOCTYPE html>
<html>
<head>
  <title>Carriage</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <%= stylesheet_link_tag    "carriage/application", media: "all" %>
  <%= stylesheet_link_tag    "actiontext", media: "all" %>
  <%= javascript_include_tag "trix" %>
  <%= javascript_include_tag "actiontext" %>
  <%= javascript_include_tag "carriage/campaign_preview" %>
</head>
<body class="h-screen overflow-hidden bg-gray-50 text-gray-900 antialiased">
  <% flash.each do |type, message| %>
    <div class="fixed inset-x-0 top-0 z-20 mx-auto max-w-md px-4 pt-4">
      <div class="rounded-lg border px-4 py-3 text-sm shadow-sm <%= type.to_s == "alert" ? "border-red-200 bg-red-50 text-red-700" : "border-emerald-200 bg-emerald-50 text-emerald-700" %>">
        <%= message %>
      </div>
    </div>
  <% end %>

  <%= yield %>
</body>
</html>
