<div class="mb-2 flex items-start justify-between">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight text-gray-900"><%= @segment.name %></h1>
    <p class="mt-1 text-sm text-gray-500">
      List: <%= link_to @segment.list.name, list_path(@segment.list), class: "font-medium text-indigo-600 hover:text-indigo-700" %>
      &middot; Match <%= @segment.all? ? "all" : "any" %> of <%= @segment.conditions.size %> condition(s)
    </p>
  </div>
</div>

<div class="mb-8 flex gap-3">
  <%= link_to "Edit segment", edit_segment_path(@segment), class: "inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50" %>
  <%= link_to "New campaign", new_campaign_path(campaign: { list_id: @segment.list_id, segment_id: @segment.id }), class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-500" %>
</div>

<h2 class="mb-3 text-base font-semibold text-gray-900">Conditions</h2>
<div class="mb-8 overflow-hidden rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
  <% if @segment.conditions.empty? %>
    <p class="text-sm text-gray-500">No conditions &mdash; matches every active subscriber on this list.</p>
  <% else %>
    <ul class="space-y-1 font-mono text-sm text-gray-700">
      <% @segment.conditions.each do |condition| %>
        <li><%= [ condition["field"], condition["operator"], condition["value"] ].compact.join(" ") %></li>
      <% end %>
    </ul>
  <% end %>
</div>

<div class="mb-4 flex items-center justify-between">
  <h2 class="text-base font-semibold text-gray-900">Matching subscribers <span class="font-normal text-gray-500">(<%= @subscriber_count %> active)</span></h2>
</div>

<div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
  <table class="min-w-full divide-y divide-gray-100">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Email</th>
        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Status</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @subscribers.each do |subscriber| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= subscriber.email %></td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= [ subscriber.first_name, subscriber.last_name ].compact.join(" ") %></td>
          <td class="px-6 py-4 text-sm">
            <% if subscriber.subscribed?(@segment.list.name) %>
              <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-700">Subscribed</span>
            <% else %>
              <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-600">Unsubscribed</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
