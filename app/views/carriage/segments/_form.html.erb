<%
  input_classes = "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
  select_classes = "block w-full appearance-none rounded-md border border-gray-300 bg-white px-3 py-2 pr-9 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
  label_classes = "block text-sm font-medium text-gray-700"
%>
<%= form_with model: segment, url: (segment.persisted? ? segment_path(segment) : segments_path), class: "max-w-lg space-y-5" do |f| %>
  <% if segment.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      <%= segment.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div>
    <%= label_tag :list, "List", class: label_classes %>
    <% if segment.persisted? %>
      <p class="mt-1 text-sm text-gray-900"><%= segment.list.name %></p>
      <%= f.hidden_field :list_id %>
    <% else %>
      <div class="relative mt-1">
        <%= f.collection_select :list_id, Carriage::List.order(:name), :id, :name, { prompt: true }, class: select_classes %>
        <%= lucide_icon "chevron-down", size: 16, class: "pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-gray-400" %>
      </div>
    <% end %>
  </div>

  <div>
    <%= f.label :name, class: label_classes %>
    <%= f.text_field :name, class: input_classes %>
  </div>

  <div>
    <%= f.label :match_type, "Match", class: label_classes %>
    <div class="relative mt-1">
      <%= f.select :match_type, [ [ "All conditions (AND)", "all" ], [ "Any condition (OR)", "any" ] ], {}, class: select_classes %>
      <%= lucide_icon "chevron-down", size: 16, class: "pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-gray-400" %>
    </div>
  </div>

  <div>
    <%= f.label :conditions_text, "Conditions", class: label_classes %>
    <p class="mt-1 text-sm text-gray-500">
      One condition per line: <code class="font-mono">field operator value</code>. Operators:
      <code class="font-mono">equals</code>, <code class="font-mono">contains</code>,
      <code class="font-mono">is_set</code>, <code class="font-mono">not_set</code>,
      <code class="font-mono">before</code>, <code class="font-mono">after</code>. Fields: <code class="font-mono">email</code>,
      <code class="font-mono">status</code> (subscribed/unsubscribed), <code class="font-mono">created_at</code>, or any of
      this list's custom fields. Example: <code class="font-mono">plan equals pro</code>.
    </p>
    <%= f.text_area :conditions_text, rows: 5, class: "#{input_classes} font-mono" %>
  </div>

  <%= f.submit segment.persisted? ? "Update segment" : "Create segment", class: "inline-flex cursor-pointer items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-500" %>
<% end %>
