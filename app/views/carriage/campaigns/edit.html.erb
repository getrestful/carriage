<div class="relative flex h-screen">
  <%= link_to campaign_path(@campaign), id: "campaign-edit-close", class: "absolute right-6 top-6 z-10 inline-flex items-center justify-center rounded-full border border-gray-200 bg-white p-2 text-gray-500 shadow-sm hover:bg-gray-100 hover:text-gray-900" do %>
    <%= lucide_icon "x", size: 20 %>
  <% end %>

  <div class="w-1/2 overflow-y-auto bg-white px-8 py-8">
    <h1 class="mb-6 text-2xl font-semibold tracking-tight text-gray-900">Edit campaign</h1>
    <%= render "form", campaign: @campaign %>
  </div>

  <div class="flex w-1/2 flex-col border-l border-gray-200 bg-gray-100">
    <div class="flex items-center justify-center gap-1 border-b border-gray-200 bg-white px-4 py-2">
      <button type="button" data-preview-viewport="desktop" class="preview-viewport-tab rounded-md px-3 py-1.5 text-sm font-medium flex gap-2 items-center">
        <%= lucide_icon("monitor", class: "size-4") %>
        Desktop
      </button>
      <button type="button" data-preview-viewport="mobile" class="preview-viewport-tab rounded-md px-3 py-1.5 text-sm font-medium flex gap-2 items-center">
        <%= lucide_icon("smartphone", class: "size-4") %>
        Mobile
      </button>
    </div>

    <div class="flex-1 overflow-auto p-6">
      <iframe
        id="campaign-preview-frame"
        title="Email preview"
        data-preview-url="<%= preview_campaign_path(@campaign) %>"
        src="<%= preview_campaign_path(@campaign) %>"
        class="mx-auto h-full w-full rounded-lg border border-gray-200 bg-white shadow-sm transition-[width] duration-150"
      ></iframe>
    </div>
  </div>
</div>
