<div class="flex h-screen flex-col">
  <div class="flex items-center justify-between border-b border-gray-200 bg-white px-8 py-4">
    <h1 class="text-lg font-semibold tracking-tight text-gray-900"><%= @campaign.name %></h1>
    <%= link_to campaign_path(@campaign), class: "inline-flex items-center justify-center rounded-full border border-gray-200 bg-white p-2 text-gray-500 shadow-sm hover:bg-gray-100 hover:text-gray-900" do %>
      <%= lucide_icon "x", size: 20 %>
    <% end %>
  </div>

  <div class="flex flex-1 flex-col overflow-hidden bg-gray-100">
    <%= render "preview_pane", preview_url: preview_campaign_path(@campaign) %>
  </div>
</div>
