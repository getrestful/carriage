<%= form_with model: subscriber, url: (subscriber.persisted? ? list_subscriber_path(list, subscriber) : list_subscribers_path(list)), class: "max-w-lg space-y-5" do |f| %>
  <% if subscriber.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      <%= subscriber.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
    <%= f.email_field :email, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :first_name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :first_name, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :last_name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :last_name, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
  </div>

  <% list.field_names.each do |field_name| %>
    <div>
      <%= label_tag "subscriber_custom_fields_#{field_name}", field_name, class: "block text-sm font-medium text-gray-700" %>
      <%= text_field_tag "subscriber[custom_fields][#{field_name}]", subscriber.custom_fields[field_name], id: "subscriber_custom_fields_#{field_name}", class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
  <% end %>

  <% if subscription %>
    <div class="flex items-center gap-2">
      <%= check_box_tag "subscriber[subscribed]", "1", subscription.unsubscribed_at.nil?, id: "subscriber_subscribed", class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
      <%= label_tag "subscriber_subscribed", "Subscribed to #{list.name}", class: "text-sm font-medium text-gray-700" %>
    </div>
  <% end %>

  <%= f.submit subscriber.persisted? ? "Update subscriber" : "Add subscriber", class: "inline-flex cursor-pointer items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-500" %>
<% end %>
