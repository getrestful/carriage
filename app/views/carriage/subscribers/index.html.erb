<h1 class="mb-6 text-2xl font-semibold tracking-tight text-gray-900"><%= @list.name %> subscribers</h1>

<div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
  <table class="min-w-full divide-y divide-gray-100">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Email</th>
        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500">Status</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @subscriptions.each do |subscription| %>
        <% subscriber = subscription.subscriber %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= subscriber.email %></td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= [ subscriber.first_name, subscriber.last_name ].compact.join(" ") %></td>
          <td class="px-6 py-4 text-sm"><%= render "carriage/shared/status_badge", status: subscription.status %></td>
          <td class="px-6 py-2 text-right text-sm">
            <div class="flex items-center justify-end gap-4 leading-none">
              <%= link_to edit_list_subscriber_path(@list, subscriber), class: "inline-flex items-center gap-2 font-medium text-indigo-600 hover:bg-neutral-200 cursor-pointer rounded p-2" do %>
                <%= lucide_icon "pencil", size: 16 %>
              <% end %>
              <%= button_to list_subscriber_path(@list, subscriber), method: :delete, data: { turbo_confirm: "Remove this subscriber from the list?" }, class: "inline-flex items-center gap-2 font-medium text-red-600 hover:bg-red-700 hover:text-white p-2 cursor-pointer rounded" do %>
                <%= lucide_icon "trash-2", size: 16 %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
