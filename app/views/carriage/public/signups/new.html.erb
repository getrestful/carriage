<div class="w-full max-w-sm rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
  <h1 class="text-center text-lg font-semibold text-gray-900"><%= t(".heading", list: @list.name) %></h1>

  <%= form_with model: @subscriber, url: list_signup_path(@list), class: "mt-6 space-y-4" do |f| %>
    <% if @subscriber.errors.any? %>
      <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
        <%= @subscriber.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :email, t(".email_label"), class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, required: true, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>

    <div>
      <%= f.label :first_name, t(".first_name_label"), class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :first_name, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>

    <div>
      <%= f.label :last_name, t(".last_name_label"), class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :last_name, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>

    <% @list.field_names.each do |field_name| %>
      <div>
        <%= label_tag "subscriber_custom_fields_#{field_name}", field_name, class: "block text-sm font-medium text-gray-700" %>
        <%= text_field_tag "subscriber[custom_fields][#{field_name}]", @subscriber.custom_fields[field_name], id: "subscriber_custom_fields_#{field_name}", class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
      </div>
    <% end %>

    <%= f.submit t(".submit"), class: "w-full cursor-pointer rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-500" %>
  <% end %>
</div>
